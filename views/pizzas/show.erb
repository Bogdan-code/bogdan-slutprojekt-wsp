<div class="pizza-show">

<img class="pizza-image" src="/img/<%=@pizza["name"]%>.jpg" alt="Pepperoni pizza">


  <h2><%= @pizza['name'] %></h2>

  <p><%= @pizza['toppings'] %></p>

  <h3><%= @pizza['price'] %>kr</h3>
    <%if @logged_in%>
      <form action="/cart/add" method="post" class="purchase-bar cart-form">
      <input type="hidden" name="pizza_id" value="<%= @pizza["id"] %>">
      
      <div class="qty-controls">
        <button class="qty-btn" type="button" data-action="minus">−</button>
        <input type="number" class="qty-input" name="amount" value="1" min="1" readonly>
        <button class="qty-btn" type="button" data-action="plus">+</button>
      </div>
      <button class="add-btn" type="submit">Add</button>
    </form>
    <%end%>
  <% if @isadmin %>
  <form action="/pizza/<%= @pizza['id'] %>/edit" method="get">
    <button class="deleteuser">Edit pizza</button>
  </form>
    <form action="/pizza/<%= @pizza['id'] %>/delete" method="post">
    <button class="deleteuser">Delete pizza</button>
  </form>
  <% end %>


</div>