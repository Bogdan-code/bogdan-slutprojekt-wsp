<h2>Create pizza</h2>

<form action="/pizzas/create" method="post" class="create-form">

  <label>Name</label>
  <input type="text" name="name" required>

  <label>Price</label>
  <input type="number" name="price" step="0.01" required>

  <label>Toppings</label>
  <input type="text" name="toppings" required>

  <button type="submit">Create pizza</button>

</form>