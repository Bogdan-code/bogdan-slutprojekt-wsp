
<div class="pizza-main">
  <% @pizzas.each do |pizza|%>
  <div class="pizza-item">
    <img onclick="window.location.href='/pizzas/<%=pizza["id"]%>'" class="pizza-image" src="/img/<%=pizza["name"]%>.jpg" alt="Pepperoni pizza">
    <h3><a href="/pizzas/<%=pizza["id"]%>"><%=pizza["name"]%></a></h3>
    <span class="price"><%=pizza["price"]%>kr</span>
    <%if @logged_in%>

    <form action="/cart/add" method="post" class="purchase-bar cart-form">
      <input type="hidden" name="pizza_id" value="<%= pizza["id"] %>">
      
      <div class="qty-controls">
        <button class="qty-btn" type="button" data-action="minus">−</button>
        <input type="number" class="qty-input" name="amount" value="1" min="1" readonly>
        <button class="qty-btn" type="button" data-action="plus">+</button>
      </div>
      <button class="add-btn" type="submit">Add</button>
    </form>

    <%end%>
  </div>
  <%end%>
    <%if @isadmin%>
    <div onclick="window.location.href='/main/create'" class="pizza-item">
      <img class="pizza-image" src="/img/pluspizza.png" alt="add-pizza">
      <h3>CREATE PIZZA</h3>
    </div>
    <%end%>
</div>

